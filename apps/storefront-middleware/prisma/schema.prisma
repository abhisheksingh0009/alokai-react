generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int       @id @default(autoincrement())
  username         String?   @unique
  name             String?
  title            String?
  firstName        String?
  lastName         String?
  email            String    @unique
  password         String
  phone            String?
  dateOfBirth      DateTime? @db.Date
  marketingConsent Boolean   @default(false)
  createdAt        DateTime  @default(now())
  reviews          Review[]
}

model ProductDetails {
  id                   Int      @id
  title                String
  description          String?
  category             String?
  price                Decimal? @db.Decimal(10, 2)
  discountPercentage   Decimal? @db.Decimal(5, 2)  @map("discountpercentage")
  rating               Decimal? @db.Decimal(3, 2)
  stock                Int?
  brand                String?
  sku                  String?
  weight               Decimal? @db.Decimal(5, 2)
  warrantyInformation  String?  @map("warrantyinformation")
  shippingInformation  String?  @map("shippinginformation")
  availabilityStatus   String?  @map("availabilitystatus")
  returnPolicy         String?  @map("returnpolicy")
  minimumOrderQuantity Int?     @map("minimumorderquantity")
  thumbnail            String?
  reviews              Review[]

  @@map("productdetails")
}

model Cart {
  id        Int      @id @default(autoincrement())
  userEmail String   @map("user_email")
  productId Int      @map("product_id")
  quantity  Int      @default(1)
  addedAt   DateTime @default(now()) @map("added_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@unique([userEmail, productId])
  @@map("cart")
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userEmail String   @map("user_email")
  productId Int      @map("product_id")
  addedAt   DateTime @default(now()) @map("added_at")

  @@unique([userEmail, productId])
  @@map("wishlist")
}

model Review {
  id           Int            @id @default(autoincrement())
  comment      String
  likes        Int            @default(0)
  providerName String         @map("provider_name")
  productId    Int            @map("product_id")
  userEmail    String         @map("user_email")
  rating       Int            @default(5)
  createdAt    DateTime       @default(now()) @map("created_at")

  product ProductDetails @relation(fields: [productId], references: [id])
  user    User           @relation(fields: [userEmail], references: [email])

  @@map("reviews")
}
